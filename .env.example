# Frontend environment variables

# Supabase (database only, storage moved to R2)
VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare R2 Upload Worker
# Local dev: http://localhost:8787
# Production: https://psc-upload-worker.{your-account}.workers.dev
VITE_UPLOAD_WORKER_URL=http://localhost:8787

# Upload auth secret — must match PSC_SECRET Wrangler secret on the worker
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_UPLOAD_SECRET=your-secret-here

# R2 Public URL (for audio playback)
# Format: https://pub-{hash}.r2.dev or your custom domain
VITE_R2_PUBLIC_URL=https://pub-placeholder.r2.dev
